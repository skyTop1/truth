{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "祭台"
      }
    },
    {
      "path": "pages/workbench/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "祖域"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-sub/system",
      "pages": [
        {
          "path": "theme-preview",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "主题预览"
          }
        }
      ]
    },
    {
      "root": "pages-sub/cyber",
      "pages": [
        {
          "path": "ritual-entry",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "接入祖域"
          }
        },
        {
          "path": "ritual-result",
          "style": {
            "navigationStyle": "custom",
            "navigationBarTitleText": "结果页"
          }
        }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "Truth",
    "navigationBarBackgroundColor": "#F5F7F8",
    "backgroundColor": "#F5F7F8"
  }
}
